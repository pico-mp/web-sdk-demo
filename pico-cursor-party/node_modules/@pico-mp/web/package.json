{
  "name": "@pico-mp/web",
  "version": "0.1.0",
  "description": "PicoMP Web SDK — browser-based multiplayer SDK for PicoMP Cloud",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "multiplayer",
    "websocket",
    "realtime",
    "picomp",
    "game",
    "sdk"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^4.1.1"
  }
}
